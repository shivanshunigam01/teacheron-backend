# =============================================================================
# TeacherPoint Backend — environment template
# Copy to .env and fill in real values. Never commit .env to git.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
BASE_URL=http://localhost:4000
CLIENT_URL=http://localhost:5173
API_PREFIX=/api/v1
MAIL_CLIENT_URL=http://localhost:5173
# MAIL_API_URL=http://localhost:4000
# MAIL_LOGO_URL=https://api.teacherpoint.org/assets/email/teacherspoints-logo.png
# MAIL_ALLOW_LOCAL_URLS=true

# ── Database (MongoDB Atlas — required, no localhost fallback) ────────────────
# MONGODB_URI and DATABASE_URL are also accepted as aliases.
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/teacherpoint?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace_me_access_secret_32_chars_minimum
JWT_REFRESH_SECRET=replace_me_refresh_secret_32_chars_minimum
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
BCRYPT_ROUNDS=10

# ── Google OAuth (must match frontend VITE_GOOGLE_CLIENT_ID) ──────────────────
GOOGLE_CLIENT_ID=

# ── SMTP ──────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM_NAME=TeacherPoint
MAIL_FROM_EMAIL=

# ── Uploads ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=25

# ── Cloudinary ────────────────────────────────────────────────────────────────
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# CLOUDINARY_CLOUD_NAME=

# ── Geo ───────────────────────────────────────────────────────────────────────
GEOAPIFY_API_KEY=

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,https://teacherpoint.org,https://www.teacherpoint.org

# ── Payments — Razorpay ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Payments — Stripe (optional) ──────────────────────────────────────────────
STRIPE_SECRET_KEY=

# ── WhatsApp OTP — AiSensy ────────────────────────────────────────────────────
AISENSY_API_ENDPOINT=https://backend.aisensy.com/campaign/t1/api/v2
AISENSY_API_KEY=
AISENSY_CAMPAIGN_NAME=teacherpoint
AISENSY_TEMPLATE_NAME=
AISENSY_CHANNEL=WhatsApp
AISENSY_USER_NAME=TeacherPoint
AISENSY_SOURCE=auth-otp
AISENSY_OTP_PARAM_KEY=FirstName
AISENSY_USE_COPY_CODE_BUTTON=true

# ── WhatsApp OTP — timing & security ──────────────────────────────────────────
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
OTP_RESEND_SECONDS=60
OTP_MAX_ATTEMPTS=5
OTP_LOCK_MINUTES=15

# ── Debug (optional) ──────────────────────────────────────────────────────────
# AUTH_ROUTE_DEBUG=true
