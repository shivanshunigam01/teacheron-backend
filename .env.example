# Server
NODE_ENV=development
PORT=5000
API_BASE_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173
API_PREFIX=/api/v1

# Database
MONGO_URI=mongodb://localhost:27017/teacherpoint

# JWT
JWT_ACCESS_SECRET=replace_me_access_secret_32_chars_minimum
JWT_REFRESH_SECRET=replace_me_refresh_secret_32_chars_minimum
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
BCRYPT_ROUNDS=10

# SMTP (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM_NAME=TeacherPoint
MAIL_FROM_EMAIL=no-reply@teacherpoint.com

# Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# Geo (optional)
GEOAPIFY_API_KEY=

# Rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# CORS — handled in code (all origins). Legacy list unused unless you customize middleware.
CORS_ORIGINS=*
