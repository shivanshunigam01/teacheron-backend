# Server
NODE_ENV=development
PORT=5000
API_BASE_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173
# Links in transactional emails (buttons, course URLs). Always set on production:
MAIL_CLIENT_URL=https://www.teacherpoint.in
# MAIL_API_URL=https://api.teacherpoint.in
# MAIL_LOGO_URL=https://www.teacherpoint.in/teacherspoints-logo.png
# Set MAIL_ALLOW_LOCAL_URLS=true only when testing emails locally with localhost links
API_PREFIX=/api/v1

# Database
MONGO_URI=mongodb://localhost:27017/teacherpoint

# JWT
JWT_ACCESS_SECRET=replace_me_access_secret_32_chars_minimum
JWT_REFRESH_SECRET=replace_me_refresh_secret_32_chars_minimum
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
BCRYPT_ROUNDS=10

# Google OAuth — must match frontend VITE_GOOGLE_CLIENT_ID exactly
GOOGLE_CLIENT_ID=127339398195-5gghcqf84esnl3gj8ld6r90qu5dc10a0.apps.googleusercontent.com

# SMTP — required in production for student/teacher welcome emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM_NAME=TeachersPoints
MAIL_FROM_EMAIL=
# Logo in emails (optional — defaults to MAIL_CLIENT_URL or CLIENT_URL/teacherspoints-logo.png)
# MAIL_LOGO_URL=https://www.teacherpoint.in/teacherspoints-logo.png
# Welcome emails are sent on student/teacher signup when SMTP is configured (env or Admin → Mail settings).

# Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=25
# Raise for large video uploads in admin Banners & Ads panel

# Cloudinary — profile photos (set CLOUDINARY_URL from Cloudinary dashboard)
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# CLOUDINARY_CLOUD_NAME=your_cloud_name

# Geo (optional)
GEOAPIFY_API_KEY=

# Rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# CORS — configured in src/middleware/cors.middleware.js (ALLOWED_ORIGINS whitelist)
# Legacy env list kept for reference; not used by the cors package middleware.
CORS_ORIGINS=https://teacherpoint.in,https://www.teacherpoint.in,http://localhost:3000,http://localhost:5173
