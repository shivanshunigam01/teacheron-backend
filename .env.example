# Server
NODE_ENV=development
PORT=5000
API_BASE_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173
API_PREFIX=/api/v1

# Database
MONGO_URI=mongodb://localhost:27017/teacherpoint

# JWT
JWT_ACCESS_SECRET=replace_me_access_secret_32_chars_minimum
JWT_REFRESH_SECRET=replace_me_refresh_secret_32_chars_minimum
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
BCRYPT_ROUNDS=10

# SMTP (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM_NAME=TeachersPoints
MAIL_FROM_EMAIL=no-reply@teacherpoint.com
# Welcome emails are sent on student/teacher signup when SMTP_USER and SMTP_PASS are set.

# Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=25
# Raise for large video uploads in admin Banners & Ads panel

# Geo (optional)
GEOAPIFY_API_KEY=

# Rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# CORS — configured in src/middleware/cors.middleware.js (ALLOWED_ORIGINS whitelist)
# Legacy env list kept for reference; not used by the cors package middleware.
CORS_ORIGINS=https://teacherpoint.in,https://www.teacherpoint.in,http://localhost:3000,http://localhost:5173
